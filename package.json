{
  "name": "storz-bickel-card",
  "version": "0.1.0",
  "type": "module",
  "description": "Companion Lovelace card for the Storz & Bickel Home Assistant integration.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nredd/hacs-storz-bickel-card.git"
  },
  "author": "Nicholas Redd @nredd",
  "license": "MIT",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "lovelace",
    "custom-cards"
  ],
  "scripts": {
    "build": "NODE_ENV=production bun build src/storz-bickel-card.ts --outfile=dist/storz-bickel-card.js --minify --format=esm --target=browser",
    "dev": "bun build src/storz-bickel-card.ts --outfile=dist/storz-bickel-card.js --format=esm --target=browser --watch",
    "serve": "bun run script/dev-server.ts",
    "check": "tsc --noEmit",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "test": "bun test --coverage"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
