#!/bin/bash

# script/lint: Lint and format TypeScript, applying fixes
#
# Runs Biome (lint + format) in write mode. For the check-only variant used
# by CI, see script/lint-check.
#
# Usage:
#   ./script/lint

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"

require_bun

log_header "Linting TypeScript with Biome (fix mode)"
bunx biome check --write .

log_success "Lint completed"
